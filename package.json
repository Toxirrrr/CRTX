{
  "name": "crtx",
  "version": "1.0.0",
  "description": "Provider-neutral AI coordination runtime",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "route": "ts-node src/cli/route.ts",
    "test": "npx ts-node tests/test_token.ts && npx ts-node tests/test_rag.ts && npx ts-node tests/test_runtime.ts && npx ts-node tests/test_orchestration.ts",
    "test:runtime": "ts-node tests/test_runtime.ts",
    "test:rag": "ts-node tests/test_rag.ts",
    "test:orchestration": "ts-node tests/test_orchestration.ts",
    "test:token": "ts-node tests/test_token.ts",
    "test:stress": "ts-node tests/stress_tests.ts",
    "postinstall": "node scripts/bootstrap.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "vectra": "^0.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
