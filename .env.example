# Copy to `.env` (gitignored) and fill in. NEVER commit real values.

# Telegram digest (opt-in, run with `npm run notify`).
# Get a token from @BotFather. If the one you used in chat was exposed,
# revoke it in @BotFather and issue a fresh one.
TELEGRAM_BOT_TOKEN=

# Optional: target chat id. Leave blank to auto-discover from getUpdates
# (you must send /start to the bot at least once first).
TELEGRAM_CHAT_ID=

# 'summary' (default) = id/title/status/risk only — no task notes.
# 'full' = also include task notes (audit/exploit detail!) — private chats only.
TELEGRAM_DETAIL=summary
